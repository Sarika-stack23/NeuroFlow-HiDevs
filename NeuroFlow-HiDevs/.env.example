# ─── Database ────────────────────────────────────────────────────
POSTGRES_PASSWORD=changeme_strong_password   # Required
POSTGRES_URL=postgresql://neuroflow:changeme_strong_password@localhost:5432/neuroflow

# ─── Redis ───────────────────────────────────────────────────────
REDIS_PASSWORD=changeme_redis_password       # Required
REDIS_URL=redis://:changeme_redis_password@localhost:6379/0

# ─── LLM Providers ───────────────────────────────────────────────
GROQ_API_KEY=gsk_...                        # Required — chat, generation, evaluation
OPENAI_API_KEY=sk-...                        # Required — embeddings only                        # Required
ANTHROPIC_API_KEY=                           # Optional

# ─── MLflow ──────────────────────────────────────────────────────
MLFLOW_TRACKING_URI=postgresql://neuroflow:changeme_strong_password@localhost:5432/mlflow

# ─── Security ────────────────────────────────────────────────────
JWT_SECRET_KEY=                              # Required: openssl rand -hex 32
PLUGIN_SECRETS_KEY=                          # Required: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"

# ─── Telemetry ───────────────────────────────────────────────────
OTEL_EXPORTER_OTLP_ENDPOINT=http://jaeger:4317   # Optional
SENTRY_DSN=                                       # Optional

# ─── App ─────────────────────────────────────────────────────────
ENVIRONMENT=development                      # development | staging | production
LOG_LEVEL=INFO                               # DEBUG | INFO | WARNING
